# ══════════════════════════════════════════════════
# NOTAM Classification — Environment Variables
# Copier en .env et adapter les valeurs
# ══════════════════════════════════════════════════

# Base de données
DATABASE_URL=postgresql://notam_user:notam_pass@localhost:5432/notam_db
# Fallback SQLite (développement local sans Docker)
# DATABASE_URL=sqlite:///data/processed/notam_dev.db

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=notam-classification

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1

# PostgreSQL (Docker)
POSTGRES_DB=notam_db
POSTGRES_USER=notam_user
POSTGRES_PASSWORD=notam_pass
POSTGRES_PORT=5432

# Sécurité
SECRET_KEY=change-me-in-production